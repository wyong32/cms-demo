# =============================================================================
# cms-api 环境变量模板（可复制为 .env 后填写；不要提交真实密钥）
# =============================================================================

# -----------------------------------------------------------------------------
# 数据库（PostgreSQL，Prisma）
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# -----------------------------------------------------------------------------
# 认证（JWT）
# -----------------------------------------------------------------------------
JWT_SECRET="请改为足够长的随机字符串"

# -----------------------------------------------------------------------------
# 服务运行
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# 可选：允许跨域的前端 Origin，逗号分隔（生产部署前端域名与 API 分离时常用）
# CORS_ORIGIN=https://your-app.example.com,https://www.your-app.example.com

# -----------------------------------------------------------------------------
# 图片上传（Cloudinary）
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# -----------------------------------------------------------------------------
# AI（默认 Gemini；mock 会主动报错，需真实密钥）
# -----------------------------------------------------------------------------
# 可选值：gemini | openai | claude | mock
AI_PROVIDER=gemini
GOOGLE_API_KEY=your-google-api-key
# 稳定：gemini-2.5-flash / gemini-2.5-pro；预览：gemini-3-flash-preview 等（以官方文档为准）
GEMINI_MODEL=gemini-2.5-flash

# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=your-anthropic-api-key
# CLAUDE_MODEL=claude-3-haiku-20240307
